<!DOCTYPE html>
<html lang="es" data-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Flota STE | Autobuses</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>

    <%- include('../partials/sidebar') %>
        <div class="main-content d-flex flex-column">
            <%- include('../partials/header') %>

                <main class="flex-grow-1 p-4">
                    <div class="container-fluid">
                        <h1 class="display-5 fw-bold mb-4 text-primary">Gestión del Personal</h1>

                        <div class="row g-4">
                            <div class="col-lg-4">
                                <div class="card shadow-lg border-0">
                                    <div class="card-header bg-primary text-white">
                                        <h5 class="mb-0">Registrar Personal</h5>
                                    </div>
                                    <div class="card-body">
                                        <form action="/admin/mantenimientos/nuevo" method="POST">
                                            <div class="mb-3">
                                                <label>Expediente</label>
                                                <input type="text" name="ot" class="form-control" required>
                                            </div>
                                            <div class="mb-3">
                                                <label>Nombre Completo (Empezando por nombre)</label>
                                                <input type="text" name="codigo" class="form-control" required>
                                            </div>
                                            <div class="mb-3">
                                                <label>Puesto</label>
                                                <select name="modelo" class="form-select">
                                                    <option>Operario de primera</option>
                                                    <option>Operario de segunda</option>
                                                    <option>Técnico</option>
                                                    <option>Técnico Especialista</option>
                                                    <option>Supervisor Especialista</option>
                                                    <option>Subjefe de oficina</option>
                                                    <option>Jefe de oficina</option>
                                                    <option>Subjefe de área</option>
                                                    <option>Jefe de área</option>
                                                    <option>Subgerente</option>
                                                    <option>Gerente</option>
                                                </select>
                                            </div>
                                            <button type="submit" class="btn btn-success w-100">Guardar
                                                Personal</button>
                                        </form>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-8">
                                <div class="card shadow-lg border-0">
                                    <div class="card-header bg-dark text-white">
                                        <h5>Lista de Personal Activo, Baja, Vacaciones e Incapacidad</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="table-responsive">
                                            <table class="table table-hover">
                                                <thead class="table-dark">
                                                    <tr>
                                                        <th>Orden de Trabajo</th>
                                                        <th>Generación</th>
                                                        <th>Numero de Trolebus</th>
                                                        <th>Modelo</th>
                                                        <th>Estado</th>
                                                        <th>Acciones</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr>
                                                        <td>ABC-123</td>
                                                        <td>20000</td>
                                                        <td>20001</td>
                                                        <td>Yutong ZK6128</td>
                                                        <td><span class="badge bg-success">En ruta</span></td>
                                                        <td><button class="btn btn-sm btn-warning"><i
                                                                    class="bi bi-pencil"></i></button></td>
                                                    </tr>
                                                    <!-- más filas aquí -->
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </main>

                <%- include('../partials/footer') %>
        </div>

        <script src="/js/dashboard.js"></script>
        <script src="/js/dashboard.js"></script>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        <script src="/js/dashboard.js"></script>
</body>

</html>