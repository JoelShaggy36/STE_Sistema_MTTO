<!DOCTYPE html>
<html lang="es" data-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Flota STE | Autobuses</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>

    <%- include('../partials/sidebar') %>

        <div class="main-content d-flex flex-column">
            <%- include('../partials/header') %>

                <main class="flex-grow-1 p-4">
                    <div class="container-fluid">
                        <h1 class="display-5 fw-bold mb-4 text-primary">Gestión de Autobuses</h1>

                        <div class="row g-4">
                            <!-- Formulario de registro/edit -->
                            <div class="col-lg-4">
                                <div class="card shadow-lg border-0">
                                    <div class="card-header bg-primary text-white">
                                        <h5 class="mb-0">Registrar/Editar Autobús</h5>
                                    </div>
                                    <div class="card-body">
                                        <form action="/admin/buses/nuevo" method="POST">
                                            <!-- Para edit, cambia a /editar/:id -->
                                            <div class="mb-3">
                                                <label>Placa (opcional)</label>
                                                <input type="text" name="placa" class="form-control">
                                            </div>
                                            <div class="mb-3">
                                                <label>Generación (autocomplete)</label>
                                                <input type="text" name="generacion_id" class="form-control"
                                                    list="generacionesList" required>
                                                <datalist id="generacionesList">
                                                    <% generaciones.forEach(gen=> { %>
                                                        <option value="<%= gen.id %>">
                                                            <%= gen.codigo %>
                                                        </option>
                                                        <% }) %>
                                                </datalist>
                                            </div>
                                            <div class="mb-3">
                                                <label>Modelo (autocomplete)</label>
                                                <input type="text" name="modelo_id" class="form-control"
                                                    list="modelosList" required>
                                                <datalist id="modelosList">
                                                    <% modelos.forEach(mod=> { %>
                                                        <option value="<%= mod.id %>">
                                                            <%= mod.nombre %>
                                                        </option>
                                                        <% }) %>
                                                </datalist>
                                            </div>
                                            <div class="mb-3">
                                                <label>Depósito Base (obligatorio)</label>
                                                <select name="deposito_base_id" class="form-select" required>
                                                    <option value="">Selecciona...</option>
                                                    <% depositos.forEach(dep=> { %>
                                                        <option value="<%= dep.id %>">
                                                            <%= dep.nombre %>
                                                        </option>
                                                        <% }) %>
                                                </select>
                                            </div>
                                            <div class="mb-3">
                                                <label>Depósito Actual (editable)</label>
                                                <input type="text" name="deposito_actual_id" class="form-control"
                                                    list="depositosList" required>
                                                <datalist id="depositosList">
                                                    <% depositos.forEach(dep=> { %>
                                                        <option value="<%= dep.id %>">
                                                            <%= dep.nombre %>
                                                        </option>
                                                        <% } ) %>
                                                </datalist>
                                            </div>
                                            <div class="mb-3">
                                                <label>KM Actual (opcional)</label>
                                                <input type="number" name="km_actual" class="form-control">
                                            </div>
                                            <div class="mb-3">
                                                <label>Fecha de Ingreso (obligatorio)</label>
                                                <input type="date" name="fecha_ingreso" class="form-control" required>
                                            </div>
                                            <div class="mb-3">
                                                <label>Estado (autocomplete 'activo')</label>
                                                <input type="text" name="estado" class="form-control" value="activo"
                                                    list="estadosList" required>
                                                <datalist id="estadosList">
                                                    <option value="activo">
                                                    <option value="baja">
                                                </datalist>
                                            </div>
                                            <div class="mb-3">
                                                <label>Kilómetros entre Mantenimientos (calculado, solo ver)</label>
                                                <input type="number" name="kilometros_entre_mantenimientos"
                                                    class="form-control" readonly>
                                            </div>
                                            <div class="mb-3">
                                                <label>Observaciones (opcional)</label>
                                                <textarea name="observaciones" class="form-control"></textarea>
                                            </div>
                                            <button type="submit" class="btn btn-success w-100">Guardar</button>
                                        </form>
                                    </div>
                                </div>
                            </div>

                            <!-- Lista de buses -->
                            <div class="col-lg-8">
                                <div class="card shadow-lg border-0">
                                    <div class="card-header bg-dark text-white">
                                        <h5>Lista de Autobuses</h5>
                                    </div>
                                    <div class="card-body">
                                        <table class="table table-hover table-striped">
                                            <thead>
                                                <tr>
                                                    <th>Número</th>
                                                    <th>Placa</th>
                                                    <th>Generación</th>
                                                    <th>Modelo</th>
                                                    <th>Depósito</th>
                                                    <th>KM</th>
                                                    <th>Fecha</th>
                                                    <th>Estado</th>
                                                    <th>Acciones</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% buses.forEach(bus=> { %>
                                                    <tr>
                                                        <td>
                                                            <%= bus.numero_identificador %>
                                                        </td>
                                                        <td>
                                                            <%= bus.placa %>
                                                        </td>
                                                        <td>
                                                            <%= bus.generacion %>
                                                        </td>
                                                        <td>
                                                            <%= bus.modelo %>
                                                        </td>
                                                        <td>
                                                            <%= bus.deposito_base %>
                                                        </td>
                                                        <td>
                                                            <%= bus.km_actual %>
                                                        </td>
                                                        <td>
                                                            <%= bus.fecha_ingreso %>
                                                        </td>
                                                        <td>
                                                            <%= bus.estado %>
                                                        </td>
                                                        <td>
                                                            <a href="/admin/buses/editar/<%= bus.id %>"
                                                                class="btn btn-warning btn-sm"><i
                                                                    class="bi bi-pencil"></i></a>
                                                            <a href="/admin/buses/eliminar/<%= bus.id %>"
                                                                class="btn btn-danger btn-sm"
                                                                onclick="return confirm('¿Seguro de eliminar?')"><i
                                                                    class="bi bi-trash"></i></a>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </main>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>