<header class="topbar d-flex justify-content-between align-items-center px-4 py-3 bg-primary text-white shadow-sm">
    <div class="d-flex align-items-center gap-3">
        <button class="btn btn-primary d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebar">
            <i class="bi bi-list fs-3"></i>
        </button>
        <img src="/img/LogoSTE.png" alt="Logo STE" height="45">
        
    </div>

    <div class="d-flex align-items-center gap-3">
        <button id="themeToggle" class="btn btn-outline-light btn-sm">
            <i class="bi bi-moon-stars-fill"></i>
        </button>
        <span class="fw-bold d-none d-sm-block">
            <%= user?.nombre || user?.username %>
        </span>
        <a href="/logout" class="btn btn-outline-danger btn-sm">Salir</a>
    </div>
</header>